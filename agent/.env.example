# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AWS (for S3 skill loading) ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-west-2

# ── S3 skill bucket ────────────────────────────────────────────────────────
S3_SKILL_BUCKET=qdojo-skill-files-costco
S3_SKILL_PREFIX=skills

# ── Agent behaviour ────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TURNS=40
PERMISSION_MODE=bypassPermissions   # bypassPermissions | default | allowedTools

# ── Computer tool (GUI automation) ─────────────────────────────────────────
# Set to true only when running inside a desktop/ECS container with a display
ENABLE_COMPUTER_TOOL=true
COMPUTER_DISPLAY_WIDTH=1920
COMPUTER_DISPLAY_HEIGHT=1080
